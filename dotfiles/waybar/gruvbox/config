{
  "layer": "top",
  "position": "top", 
  "height": 32,
  
  "modules-left":   ["custom/nixos","hyprland/workspaces", "tray", "custom/playerctl"],
  "modules-center": ["clock"],
  "modules-right":  ["custom/music","idle_inhibitor","temperature","backlight","pulseaudio", "network", "battery", "custom/power"],

  "wlr/taskbar": {
	"format": "{icon} {app_id}",
	"icon-size": 14,
	"icon-theme": "Papirus",
	"tooltip-format": "{title}",
	"on-click": "activate",
	"on-click-middle": "close",
  "on-click-right": "minimize-raise",
	"ignore-list": [
	    "kitty"
	],
	"app_ids-mapping": {
	}
  },
  "wlr/workspaces": {
        "disable-scroll": true,
        "sort-by-number": true,
        "on-click": "activate"
   },
  
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },

  "clock#time": {
    "interval": 1,
    "format": " ΎΑΩ {:%H:%M:%S} ",
    "tooltip": false
  },

  "clock#date": {
    "interval": 10,
    "format": " ΎΒ│ {:%e %b %y} ", // icon: calendar-alt
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "clock": {
		"interval": 1,
		"format": "{:%I:%M %p  %A %b %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"tooltip": true
    },
   "custom/nixos": {
        "format": "ΎΝΥ ", // This is the NixOS icon from Nerd Fonts
        "tooltip": false,
        "on-click": "neofetch" // Optional: make it open your app menu
    },

   "custom/music": {
        "format": "{icon}{}",
        "format-icons": {
            "Playing": "ΎΖΕ ", // Uncomment if not using the dynamic script
            "Paused": "≤░Πξ ",
            "Stopped": "&#x202d;≤░βο " // This stop symbol is RTL. So &#x202d; is left-to-right override.
        },
        "escape": true,
        "tooltip": true,
        "exec": "./scripts/caway.sh -e",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl previous",
        "on-scroll-down": "playerctl next",
        "on-click-right": "g4music",
        "max-length": 35
    },

  "network": {
    	"interval": 1,
        "format-wifi": "≤░Τλ {essid}",
        "format-ethernet": "≤░ΙΑ  {ifname}",
        "format-linked": "≤░Τλ {essid} (No IP)",
        "format-disconnected": "≤░Τλ Disconnected",
        "format-alt": "{ifname} ({ipaddr})",
        "tooltip": true,
        "tooltip-format": "signal strength: {signalstrength}% | down speed: {bandwidthdownbits}, up speed: {bandwidthupbits}",
        "on-click-right": "exec nm-connection-editor"
  },

  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon} {volume}%", 
    "format-muted": "≤░ΨΒ Muted",
    "format-icons": {
      "headphone": " ΎΑξ ",
      "hands-free": " ΎΑξ ",
      "headset": " ΎΑξ ",
      "phone": " ΎΓΧ ",
      "portable": " ΎΓΧ ",
      "car": " ΎΗ╣ ",
       "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "states": {
     	"warning": 85
    },
    "on-scroll-up": "volume.sh --dec",
    "on-scroll-down": "volume.sh --inc",
    "smooth-scrolling-threshold": 5,
    "tooltip": false,
    "on-click": "volume.sh --toggle",
    "on-click-right": "pavucontrol"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
         "activated": "≤░ΙΙ ",
      "deactivated": "≤░ΙΚ "
     },
     "tooltip": false
  },
 
  "temperature": {
		"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
		"critical-threshold": 85,
		"interval": 1,
		"format": "<span font='12' rise='-2500'>≤░ΦΠ</span> {temperatureC}┬░C",
		"tooltip": false
	},

  "backlight": {
            "format": "≤░Δι {percent}%",
            "on-scroll-up": "brightness.sh --dec",
            "on-scroll-down": "brightness.sh --inc",
            "smooth-scrolling-threshold": 5
    },

  "battery": {
            "interval": 10,

            "states": {
                	"warning": 20,
                	"critical": 10
	            },
	            "format": "{icon} {capacity}%",
	            "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
	            "format-full": "{icon} {capacity}%",
	            "format-charging": "≤░ΓΕ {capacity}%",
            "tooltip": true
  },
    
  "custom/power": {
    "format": " έΠ╗ ",
    "on-click": "~/.config/hypr/hyprland.conf"
  },
  "custom/playerctl": {
    //"format": "<span font='12' rise='-2500'>{icon}</span> {}",
    "format": "<span font='10' rise='-1000'>≤░ΟΙ</span>  {} ",
    "format-icons": {
	"Playing": "≤░ΡΛ",
        "Paused": "≤░Πν"
    },
    	"escape": true,
   	"return-type": "json",
    	"max-length": 40,
    	"on-click": "playerctl play-pause",
    	"on-click-right": "playerctl stop",
        "on-click-middle": "killall spotify",
    	"smooth-scrolling-threshold": 10,
    	"on-scroll-up": "playerctl next",
    	"on-scroll-down": "playerctl previous",
    	"exec": "playerctl -a metadata --format '{\"text\": \"{{markup_escape(title)}} - {{artist}}\", \"tooltip\": \"{{status}} : {{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F" 
    },

  "mpd": {
    "format": " {stateIcon}   {artist} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S})   ΎΑΒ ",
    "format-disconnected": " Disconnected ΎΑΒ ",
    "format-stopped": " Stopped ΎΑΒ ",
    "interval": 2,
    "consume-icons": {
      "on": "ΎΔΕ " // Icon shows only when "consume" is on
    },
    "random-icons": {
      "off": "<span color=\"#fb4934\">ΎΒ┤ </span>", // Icon grayed out when "random" is off
      "on": "ΎΒ┤ "
    },
    "repeat-icons": {
      "on": "ΎΑη "
    },
    "single-icons": {
      "on": "ΎΑη1 "
    },
    "state-icons": {
      "paused": "ΎΒΝ",
      "playing": "ΎΒΜ"
    },
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  }
}
