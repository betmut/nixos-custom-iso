{
  "layer": "top",
  "position": "top", 
  "height": 32,
  
  "modules-left":   ["custom/nixos", "hyprland/workspaces", "tray", "custom/playerctl"],
  "modules-center": ["clock"],
  "modules-right":  ["idle_inhibitor","temperature", "cpu", "memory", "network", "battery", "custom/power"],

  "wlr/taskbar": {
	"format": "{icon} {app_id}",
	"icon-size": 14,
	"icon-theme": "Papirus",
	"tooltip-format": "{title}",
	"on-click": "activate",
	"on-click-middle": "close",
  "on-click-right": "minimize-raise",
	"ignore-list": [
	    "kitty"
	],
	"app_ids-mapping": {
	}
  },
  "wlr/workspaces": {
        "disable-scroll": true,
        "sort-by-number": true,
        "on-click": "activate"
   },
  
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },

  "clock#time": {
    "interval": 1,
    "format": " ’ĆŚ {:%H:%M:%S} ",
    "tooltip": false
  },

  "clock#date": {
    "interval": 10,
    "format": " ’ü│ {:%e %b %y} ", // icon: calendar-alt
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "clock": {
		"interval": 1,
		"format": "{:%I:%M %p  %A %b %d}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"tooltip": true
    },
   "custom/nixos": {
        "format": "’īō ", // This is the NixOS icon from Nerd Fonts
        "tooltip": true,
        "tooltip-format": "About Device",
        "on-click": "kitty --hold fastfetch" // Optional: make it open your app menu
    },

   "custom/music": {
        "format": "{icon}{}",
        "format-icons": {
            "Playing": "’ģä ", // Uncomment if not using the dynamic script
            "Paused": "¾░Åź ",
            "Stopped": "&#x202d;¾░Ö” " // This stop symbol is RTL. So &#x202d; is left-to-right override.
        },
        "escape": true,
        "tooltip": true,
        "exec": "./scripts/caway.sh -e",
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl previous",
        "on-scroll-down": "playerctl next",
        "on-click-right": "g4music",
        "max-length": 35
    },

  "network": {
    	"interval": 1,
        "format-wifi": "¾░Æó  {essid}",
        "format-ethernet": "¾░łĆ  {ifname}",
        "format-linked": "¾░Æó {essid} (No IP)",
        "format-disconnected": "¾░×ā Disconnected",
        "format-alt": "{ifname} ({ipaddr})",
        "tooltip": true,
        "tooltip-format": "signal strength: {signalStrength} | down speed: {bandwidthDownBits}, up speed: {bandwidthUpBits}"
  },

  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon}   {volume}%", 
    "format-muted": "¾░¢ü Muted",
    "format-icons": {
      "headphone": " ’Ćź ",
      "hands-free": " ’Ćź ",
      "headset": " ’Ćź ",
      "phone": " ’éĢ ",
      "portable": " ’éĢ ",
      "car": " ’å╣ ",
       "default": ["’Ć”", "’Ć¦", "’Ć©"]
    },
    "states": {
     	"warning": 85
    },
    "on-scroll-up": "volume.sh --dec",
    "on-scroll-down": "volume.sh --inc",
    "smooth-scrolling-threshold": 5,
    "tooltip": false,
    "on-click": "volume.sh --toggle",
    "on-click-right": "pavucontrol"
  },

  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
         "activated": "¾░łł ",
      "deactivated": "¾░łē "
     },
     "tooltip": false
  },
 
  "temperature": {
		"hwmon-path": "/sys/class/hwmon/hwmon3/temp1_input",
		"critical-threshold": 85,
		"interval": 1,
		"format": "<span font='12' rise='-2500'>¾░öÅ</span> {temperatureC}┬░C",
		"tooltip": false
	},

  "cpu": {
    "interval": 2,
    "format": "’Æ╝   {usage:>2}%"
  },

  "memory": {
    "interval": 2,
    "format":"Ņ┐ģ   {percentage}%",
    "max-length": 30,
    "tooltip": true,
    "tooltip-format":"{used:0.1f}GiB/{total:0.1f}GiB used"
  },

  "backlight": {
            "format": "¾░āĀ {percent}%",
            "on-scroll-up": "brightness.sh --dec",
            "on-scroll-down": "brightness.sh --inc",
            "smooth-scrolling-threshold": 5
    },

  "battery": {
            "interval": 10,

            "states": {
                	"warning": 20,
                	"critical": 10
	            },
	            "format": "{icon} {capacity}%",
	            "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éü", "¾░éé", "¾░ü╣"],
	            "format-full": "{icon} {capacity}%",
	            "format-charging": "¾░éä {capacity}%",
            "tooltip": true
  },
    
  "custom/power": {
    "format": " ŌÅ╗ ",
    "on-click": "wlogout",
    "tooltip": false
  },
  "custom/playerctl": {
    //"format": "<span font='12' rise='-2500'>{icon}</span> {}",
    "format": "<span font='10' rise='-1000'>¾░Äł</span>  {} ",
    "format-icons": {
	"Playing": "¾░ÉŖ",
        "Paused": "¾░Åż"
    },
    	"escape": true,
   	"return-type": "json",
    	"max-length": 40,
    	"on-click": "playerctl play-pause",
    	"on-click-right": "playerctl stop",
        "on-click-middle": "killall spotify",
    	"smooth-scrolling-threshold": 10,
    	"on-scroll-up": "playerctl next",
    	"on-scroll-down": "playerctl previous",
    	"exec": "playerctl -a metadata --format '{\"text\": \"{{markup_escape(title)}} - {{artist}}\", \"tooltip\": \"{{status}} : {{playerName}} : {{markup_escape(title)}}\", \"alt\": \"{{status}}\", \"class\": \"{{status}}\"}' -F" 
    },

  "mpd": {
    "format": " {stateIcon}   {artist} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S})   ’Ćü ",
    "format-disconnected": " Disconnected ’Ćü ",
    "format-stopped": " Stopped ’Ćü ",
    "interval": 2,
    "consume-icons": {
      "on": "’āä " // Icon shows only when "consume" is on
    },
    "random-icons": {
      "off": "<span color=\"#fb4934\">’ü┤ </span>", // Icon grayed out when "random" is off
      "on": "’ü┤ "
    },
    "repeat-icons": {
      "on": "’Ć× "
    },
    "single-icons": {
      "on": "’Ć×1 "
    },
    "state-icons": {
      "paused": "’üī",
      "playing": "’üŗ"
    },
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous",
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  }
}
